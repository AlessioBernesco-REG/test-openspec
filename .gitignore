# ============================================
# BISHOP APP - .gitignore
# ============================================

# --------------------------------------------
# Dependencies
# --------------------------------------------
node_modules/
.pnp/
.pnp.js

# --------------------------------------------
# Build Output
# --------------------------------------------
dist/
dist-ssr/
build/
*.local

# --------------------------------------------
# Environment Variables (IMPORTANTE!)
# --------------------------------------------
# Escludi file con credenziali REALI
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# INCLUDI file template/esempio (vengono tracciati da git)
!.env.example
!.env.*.example

# --------------------------------------------
# Credentials & Tokens (IMPORTANTE!)
# --------------------------------------------
# Escludi file con credenziali REALI
.credentials
.token

# INCLUDI file template/esempio (vengono tracciati da git)
!.credentials.example

# --------------------------------------------
# Logs
# --------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --------------------------------------------
# Editor & IDE
# --------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --------------------------------------------
# OS Generated Files
# --------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --------------------------------------------
# Testing
# --------------------------------------------
coverage/
*.lcov
.nyc_output/

# --------------------------------------------
# TypeScript
# --------------------------------------------
*.tsbuildinfo

# --------------------------------------------
# Vite
# --------------------------------------------
vite.config.ts.timestamp-*

# --------------------------------------------
# Docker (local dev)
# --------------------------------------------
docker-compose.override.yml
.docker/

# --------------------------------------------
# Misc
# --------------------------------------------
*.pem
*.key
*.cert
.cache/
.temp/
.tmp/
